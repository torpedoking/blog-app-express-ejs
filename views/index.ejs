<%- include("partials/header.ejs") %>

    <section class="container-fluid">
        <div class="row d-flex align-items-center">
            <div class="col-md-6">
                <h1>My Blog</h1>
                <p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Odio eius delectus repellat ipsam, aperiam
                    voluptatum reiciendis dignissimos voluptatibus aspernatur laboriosam.</p>
            </div>
            <div class="col-md-6">
                <img class="img-fluid rounded" src="https://picsum.photos/720" alt="random image">
            </div>
        </div>
    </section>

    <section class="container-fluid mt-5">
        <div class="row">
            <div class="col-8">
                <h2>Blog Posts</h2>
                <% allPosts.forEach(post=> { %>
                    <div>
                        <h3>
                            <%= post.postTitle %>
                        </h3>
                        <p>
                            <%= post.postContent %>
                        </p>
                        <div class="d-flex">
                            <form action="/posts/<%= post.id %>?_method=DELETE" method="POST">
                                <button class="btn btn-outline-danger" type="submit">Delete</button>
                            </form>
                            <button class="btn btn-outline-secondary"><a class="link-warning"
                                    href="/posts/<%= post.id %>/edit">Edit</a></button>
                        </div>
                    </div>
                    <% }); %>

            </div>
        </div>
        </div>

    </section>

    <%- include("partials/footer.ejs") %>